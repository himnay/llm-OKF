    {
      "id": 5,
      "title": "Token Usage by Model",
      "description": "Total tokens consumed per model in selected time range (input + output combined).",
      "type": "bargauge",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 12,
        "h": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "valueMode": "color",
        "text": {},
        "minVizWidth": 0,
        "minVizHeight": 10
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-BlPu"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#5794F2",
                "value": null
              },
              {
                "color": "#B877D9",
                "value": 1000
              },
              {
                "color": "#9B30FF",
                "value": 10000
              }
            ]
          },
          "unit": "short",
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by(gen_ai_request_model) (gen_ai_client_token_usage_total{application=\"$application\",gen_ai_request_model=~\"$model\",gen_ai_token_type=\"total\"})",
          "instant": true,
          "legendFormat": "{{gen_ai_request_model}}",
          "refId": "A"
        }
      ]
    },
