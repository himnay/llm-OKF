      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": false,
            "drawStyle": "line",
            "gradientMode": "none",
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by(gen_ai_request_model) (rate(gen_ai_client_operation_seconds_count{application=\"$application\",gen_ai_request_model=~\"$model\"}[$__rate_interval]))",
          "legendFormat": "{{gen_ai_request_model}}",
          "refId": "A"
        }
      ]
