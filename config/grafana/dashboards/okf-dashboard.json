          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(gen_ai_client_token_usage_total{application=\"$application\",gen_ai_token_type=\"total\",gen_ai_request_model=~\"$model\"}[$__rate_interval]))",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
