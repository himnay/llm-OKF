          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "spanNulls": false,
            "drawStyle": "line",
            "gradientMode": "opacity",
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "showPoints": "never"
          },
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Prompt Tokens"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#73BF69",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Completion Tokens"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#B877D9",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(gen_ai_client_token_usage_total{application=\"$application\",gen_ai_request_model=~\"$model\",gen_ai_token_type=\"input\"}[$__rate_interval])) * 60",
          "legendFormat": "Prompt Tokens",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(gen_ai_client_token_usage_total{application=\"$application\",gen_ai_request_model=~\"$model\",gen_ai_token_type=\"output\"}[$__rate_interval])) * 60",
