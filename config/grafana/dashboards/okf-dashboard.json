          "expr": "sum(rate(gen_ai_client_operation_seconds_sum{application=\"$application\",gen_ai_request_model=~\"$model\"}[$__rate_interval])) / sum(rate(gen_ai_client_operation_seconds_count{application=\"$application\",gen_ai_request_model=~\"$model\"}[$__rate_interval]))",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
